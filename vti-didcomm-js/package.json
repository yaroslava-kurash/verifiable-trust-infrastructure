{
  "name": "vti-didcomm-js",
  "version": "0.1.0",
  "description": "Browser-side DIDComm v2 implementation for the Verifiable Trust Infrastructure workspace. Focused subset: authcrypt + X25519 + A256CBC-HS512 + Ed25519, no anoncrypt, no multi-recipient. See docs/05-design-notes/didcomm-js-implementation.md.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./base64url": "./src/base64url.js",
    "./multibase": "./src/multibase.js",
    "./jwk": "./src/jwk.js",
    "./concat-kdf": "./src/concat-kdf.js",
    "./x25519": "./src/x25519.js",
    "./ecdh-1pu": "./src/ecdh-1pu.js",
    "./a256cbc-hs512": "./src/a256cbc-hs512.js",
    "./pack": "./src/pack.js",
    "./unpack": "./src/unpack.js",
    "./did-key": "./src/did-key.js",
    "./did-webvh": "./src/did-webvh.js",
    "./resolver": "./src/resolver.js",
    "./vta-rest-auth": "./src/vta-rest-auth.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "build:demo": "esbuild src/index.js --bundle --format=esm --platform=browser --target=es2022 --minify --legal-comments=inline --outfile=../examples/vta-auth-demo/vendor/vti-didcomm-js.js"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "didwebvh-ts": "^2.7.4"
  },
  "private": true,
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
