{
  "$id": "https://trusttasks.org/openvtc/vtc/members/self-remove/1.0/schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VTC Members — Self-Remove",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "properties": {
        "disposition": {
          "type": "string",
