# Build output — produced by `npm run build` (invoked by
# vtc-service's build.rs). Not committed: every `cargo build`
# regenerates it, so a stale committed copy would diverge silently.
dist/

# npm install output.
node_modules/

# TypeScript incremental build cache.
*.tsbuildinfo

# Editor / IDE.
.vscode/
.idea/
.DS_Store
